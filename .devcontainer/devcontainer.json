{
    "name": "GGUF Chat Environment (GPU)",
    // GitHub Actionsでビルドし、オフラインPCでloadしたイメージ名とタグを指定
    "image": "gguf-chat:latest",
    
    // VS Code特有の設定（Python拡張機能などをコンテナ内に自動インストール）
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },

    // GPUを使用するための設定（必須）
    "runArgs": [
        "--gpus", "all"
    ],

    // モデルファイル（GGUF）をコンテナ内にマウントする設定
    // ※ "source" の部分は、オフラインPCの実際のパスに合わせて書き換えてください
    "mounts": [
        "source=C:\\llm_models,target=/app/models,type=bind,consistency=cached"
    ]
}
